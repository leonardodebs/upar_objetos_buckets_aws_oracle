# .env.example - Configuração do Uploader
# Copie este arquivo para .env nas pastas upar_aws/ ou upar_oci/

# === CONFIGURAÇÕES AWS S3 ===
AWS_REGION=us-east-1
BUCKET_NAME=nome-do-seu-bucket-aws
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# === CONFIGURAÇÕES ORACLE CLOUD (OCI) ===
# O Namespace e a Região são obrigatórios para construir o endpoint correto
OCI_REGION=sa-vinhedo-1
OCI_NAMESPACE=seu_namespace_oci
OCI_BUCKET_NAME=nome-do-seu-bucket-oci
OCI_ACCESS_KEY_ID=ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ
OCI_SECRET_ACCESS_KEY=WWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWW
